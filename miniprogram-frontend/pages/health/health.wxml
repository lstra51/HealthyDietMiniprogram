<view class="page">
  <view class="container">
    <view class="section">
      <view class="section-title">基本信息</view>
      
      <view class="form-item">
        <view class="label">身高 (cm)</view>
        <input 
          class="input" 
          type="digit" 
          placeholder="请输入身高"
          value="{{height}}"
          bindinput="onHeightInput"
        />
      </view>

      <view class="form-item">
        <view class="label">体重 (kg)</view>
        <input 
          class="input" 
          type="digit" 
          placeholder="请输入体重"
          value="{{weight}}"
          bindinput="onWeightInput"
        />
      </view>

      <view class="form-item" wx:if="{{bmi}}">
        <view class="label">BMI 指数</view>
        <view class="bmi-display">
          <text class="bmi-value">{{bmi}}</text>
          <text class="bmi-status {{bmiStatus}}">{{bmiStatus}}</text>
        </view>
      </view>

      <view class="form-item">
        <view class="label">性别</view>
        <picker mode="selector" range="{{['男', '女']}}" bindchange="onGenderChange">
          <view class="picker">{{gender}}</view>
        </picker>
      </view>
    </view>

    <view class="section">
      <view class="section-title">健康目标</view>
      <view class="goal-options">
        <view 
          class="goal-option {{goal === '减脂' ? 'active' : ''}}"
          bindtap="selectGoal"
          data-goal="减脂"
        >
          <view class="goal-icon">🔥</view>
          <view class="goal-label">减脂</view>
        </view>
        <view 
          class="goal-option {{goal === '增肌' ? 'active' : ''}}"
          bindtap="selectGoal"
          data-goal="增肌"
        >
          <view class="goal-icon">💪</view>
          <view class="goal-label">增肌</view>
        </view>
        <view 
          class="goal-option {{goal === '保持' ? 'active' : ''}}"
          bindtap="selectGoal"
          data-goal="保持"
        >
          <view class="goal-icon">⚖️</view>
          <view class="goal-label">保持</view>
        </view>
      </view>
    </view>

    <button class="save-btn" bindtap="onSave">保存信息</button>
  </view>
</view>
