.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.4;
  min-height: 72rpx;
  vertical-align: middle;
}

.picker {
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  min-height: 72rpx;
  box-sizing: border-box;
}

.bmi-display {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.bmi-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4CAF50;
}

.bmi-status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.bmi-status.thin {
  background-color: #e3f2fd;
  color: #2196f3;
}

.bmi-status.normal {
  background-color: #e8f5e9;
  color: #4CAF50;
}

.bmi-status.overweight {
  background-color: #fff3e0;
  color: #ff9800;
}

.bmi-status.fat {
  background-color: #ffebee;
  color: #f44336;
}

.goal-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.goal-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.goal-option.active {
  background-color: #e8f5e9;
  border-color: #4CAF50;
}

.goal-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.goal-label {
  font-size: 26rpx;
  color: #555555;
}

.goal-option.active .goal-label {
  color: #4CAF50;
  font-weight: 600;
}

.save-btn {
  width: 100%;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 28rpx 0;
  border: none;
  margin-top: 20rpx;
}
