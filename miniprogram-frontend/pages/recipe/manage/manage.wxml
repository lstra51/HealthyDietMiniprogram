<view class="page">
  <view class="search-section">
    <input
      class="search-input"
      placeholder="搜索食谱名称或描述"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="true">
      <view class="filter-list">
        <view
          wx:for="{{statuses}}"
          wx:key="value"
          class="filter-item {{activeStatus === item.value ? 'active' : ''}}"
          data-status="{{item.value}}"
          bindtap="onStatusTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <scroll-view class="filter-scroll category-scroll" scroll-x="true">
      <view class="filter-list">
        <view
          wx:for="{{categories}}"
          wx:key="value"
          class="filter-item {{activeCategory === item.value ? 'active' : ''}}"
          data-category="{{item.value}}"
          bindtap="onCategoryTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="recipe-list" wx:if="{{recipeList.length > 0}}">
    <view
      class="recipe-item"
      wx:for="{{recipeList}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <image
        class="recipe-image"
        src="{{item.image}}"
        mode="aspectFill"
        data-index="{{index}}"
        binderror="onImageError"
      ></image>
      <view class="recipe-info">
        <view class="recipe-name">{{item.name}}</view>
        <view class="recipe-meta">{{item.category}} · {{item.calories}} kcal</view>
        <view class="recipe-status status-{{item.status}}">{{item.statusText}}</view>
        <view class="recipe-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tagItem">{{tagItem}}</text>
        </view>
        <view class="recipe-meta" wx:if="{{item.rejectReason}}">拒绝原因：{{item.rejectReason}}</view>
      </view>
      <view class="action-group">
        <view class="action-btn edit-btn" catchtap="editRecipe" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete-btn" catchtap="deleteRecipe" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="empty-icon">食</view>
    <view class="empty-text">暂无符合条件的食谱</view>
  </view>
</view>
