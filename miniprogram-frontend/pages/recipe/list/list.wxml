<view class="page">
  <view class="search-section">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索食谱"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch">搜索</button>
      <button class="filter-btn" bindtap="toggleFilter">筛选</button>
    </view>
  </view>

  <view class="filter-panel" wx:if="{{filterOpen}}">
    <view class="filter-grid">
      <input
        class="filter-input"
        type="number"
        placeholder="最低热量"
        value="{{minCalories}}"
        data-field="minCalories"
        bindinput="onFilterInput"
      />
      <input
        class="filter-input"
        type="number"
        placeholder="最高热量"
        value="{{maxCalories}}"
        data-field="maxCalories"
        bindinput="onFilterInput"
      />
      <input
        class="filter-input"
        type="digit"
        placeholder="最低蛋白质"
        value="{{minProtein}}"
        data-field="minProtein"
        bindinput="onFilterInput"
      />
      <picker mode="selector" range="{{goals}}" value="{{goals.indexOf(goal)}}" bindchange="onGoalChange">
        <view class="goal-picker">健康目标：{{goal}}</view>
      </picker>
    </view>
    <view class="filter-actions">
      <button class="reset-btn" bindtap="resetFilters">重置</button>
      <button class="apply-btn" bindtap="applyFilters">应用筛选</button>
    </view>
  </view>

  <view class="tag-section">
    <scroll-view class="tag-scroll" scroll-x="true" enable-flex="true">
      <view class="tag-button-list">
        <view
          class="tag-button {{activeTag === '' ? 'active' : ''}}"
          data-tag=""
          bindtap="onTagTap"
        >
          全部
        </view>
        <view
          wx:for="{{availableTags}}"
          wx:key="*this"
          class="tag-button {{activeTag === item ? 'active' : ''}}"
          data-tag="{{item}}"
          bindtap="onTagTap"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="recipe-list">
    <view wx:if="{{recipes.length === 0}}" class="empty-state">暂无食谱</view>
    <view wx:else class="recipe-grid">
      <view
        wx:for="{{recipes}}"
        wx:key="id"
        class="recipe-card"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <image
          class="recipe-image"
          src="{{item.image}}"
          mode="aspectFill"
          data-index="{{index}}"
          binderror="onImageError"
        />
        <view class="recipe-info">
          <view class="recipe-name">{{item.name}}</view>
          <view class="recipe-category">{{item.category}}</view>
          <view class="recipe-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tagItem" class="tag">{{tagItem}}</text>
          </view>
          <view class="recipe-calories">{{item.calories}} kcal · 蛋白 {{item.protein || 0}}g</view>
        </view>
      </view>
    </view>
  </view>
</view>
