.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.search-section {
  padding: 20rpx;
  background-color: #ffffff;
}

.search-box {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.search-input {
  flex: 3;
  min-width: 0;
  height: 88rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.search-btn {
  flex: 1;
  height: 88rpx;
  padding: 0 20rpx;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.filter-btn {
  flex: 1;
  height: 88rpx;
  padding: 0 20rpx;
  background-color: #ffffff;
  color: #4CAF50;
  border: 1rpx solid #4CAF50;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.filter-panel {
  margin-top: 16rpx;
  padding: 20rpx;
  background-color: #ffffff;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.filter-input,
.goal-picker {
  min-height: 92rpx;
  padding: 24rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.4;
  display: flex;
  align-items: center;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.reset-btn,
.apply-btn {
  flex: 1;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1;
  padding: 18rpx 0;
}

.reset-btn {
  background-color: #eeeeee;
  color: #555555;
}

.apply-btn {
  background-color: #4CAF50;
  color: #ffffff;
}

.tag-section {
  padding: 20rpx 0;
  background-color: #ffffff;
  margin-top: 16rpx;
}

.tag-scroll {
  white-space: nowrap;
}

.tag-button-list {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.tag-button {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.tag-button.active {
  background-color: #4CAF50;
  color: #ffffff;
}

.recipe-list {
  padding: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recipe-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.recipe-image {
  width: 100%;
  height: 240rpx;
}

.recipe-info {
  padding: 16rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.recipe-category {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: #e8f5e9;
  color: #4CAF50;
  border-radius: 4rpx;
}

.recipe-calories {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 500;
}
