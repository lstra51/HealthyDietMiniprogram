.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.search-section {
  padding: 20rpx;
  background-color: #ffffff;
}

.search-box {
  display: flex;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  background-color: #f9f9f9;
}

.search-btn {
  padding: 16rpx 32rpx;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1;
}

.category-section {
  padding: 20rpx 0;
  background-color: #ffffff;
  margin-top: 16rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f0f0f0;
}

.category-item.active {
  background-color: #4CAF50;
  color: #ffffff;
}

.recipe-list {
  padding: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recipe-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.recipe-image {
  width: 100%;
  height: 240rpx;
}

.recipe-info {
  padding: 16rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.recipe-category {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: #e8f5e9;
  color: #4CAF50;
  border-radius: 4rpx;
}

.recipe-calories {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 500;
}
