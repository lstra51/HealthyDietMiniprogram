.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.status-box {
  padding: 20rpx 20rpx 0 20rpx;
}

.status-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background-color: rgba(255, 193, 7, 0.15);
  color: #ff9800;
}

.status-approved {
  background-color: rgba(76, 175, 80, 0.15);
  color: #4CAF50;
}

.status-rejected {
  background-color: rgba(244, 67, 54, 0.15);
  color: #f44336;
}

.reject-box {
  margin: 20rpx;
  padding: 24rpx;
  background-color: #f8d7da;
  border-radius: 8rpx;
}

.reject-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #721c24;
  margin-bottom: 12rpx;
}

.reject-reason {
  font-size: 26rpx;
  color: #721c24;
  line-height: 1.6;
}

.content {
  padding: 0 20rpx;
}

.section {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.recipe-image {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.info-item {
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-item .value {
  font-size: 28rpx;
  color: #333333;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.nutrition-item {
  text-align: center;
}

.nutrition-item .label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.nutrition-item .value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.list-item {
  font-size: 28rpx;
  color: #333333;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #4CAF50;
  padding: 8rpx 20rpx;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 100rpx;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.edit-btn {
  width: 100%;
  padding: 24rpx;
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
}
