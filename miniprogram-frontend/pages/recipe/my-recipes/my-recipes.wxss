.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  position: relative;
}

.recipe-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.recipe-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.recipe-category {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.recipe-calories {
  font-size: 24rpx;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.recipe-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  align-self: flex-start;
}

.recipe-status.status-pending {
  background-color: #fff3cd;
  color: #856404;
}

.recipe-status.status-approved {
  background-color: #d4edda;
  color: #155724;
}

.recipe-status.status-rejected {
  background-color: #f8d7da;
  color: #721c24;
}

.edit-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 4rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
