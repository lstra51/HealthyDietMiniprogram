<view class="page">
  <view class="header">我的食谱</view>
  
  <view class="recipe-list" wx:if="{{recipeList.length > 0}}">
    <view class="recipe-item" wx:for="{{recipeList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-status="{{item.status}}">
      <image class="recipe-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="recipe-info">
        <view class="recipe-name">{{item.name}}</view>
        <view class="recipe-category">{{item.category}}</view>
        <view class="recipe-calories">{{item.calories}}千卡</view>
        <view class="recipe-status status-{{item.status}}">
          <text wx:if="{{item.status === 'pending'}}">待审核</text>
          <text wx:elif="{{item.status === 'approved'}}">已通过</text>
          <text wx:elif="{{item.status === 'rejected'}}">已拒绝</text>
        </view>
      </view>
      <view class="edit-btn" wx:if="{{item.status === 'rejected'}}" bindtap="editRecipe" data-id="{{item.id}}">
        编辑
      </view>
    </view>
  </view>
  
  <view class="empty" wx:else>
    <view class="empty-icon">📭</view>
    <view class="empty-text">您还没有上传食谱</view>
  </view>
</view>
