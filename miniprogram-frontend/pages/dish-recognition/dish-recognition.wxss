.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.preview-section {
  width: 100%;
  aspect-ratio: 4 / 3;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.empty-preview {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 18rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #777777;
  text-align: center;
  line-height: 1.5;
}

.actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  width: 0;
  min-width: 0;
  margin: 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 18rpx 0;
  border: none;
  line-height: 1.4;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-btn.primary {
  background-color: #4CAF50;
  color: #ffffff;
}

.action-btn.secondary {
  background-color: #ffffff;
  color: #4CAF50;
}

.error-card {
  background-color: #fff7f0;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #9a4b00;
  margin-bottom: 8rpx;
}

.error-text {
  font-size: 24rpx;
  color: #9a4b00;
  line-height: 1.5;
  word-break: break-all;
}

.result-card,
.candidate-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.result-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222222;
}

.result-subtitle {
  font-size: 24rpx;
  color: #888888;
  margin-top: 8rpx;
}

.confidence {
  font-size: 24rpx;
  color: #4CAF50;
  background-color: #e8f5e9;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.calorie-row {
  background-color: #f7fbf7;
  border-radius: 12rpx;
  padding: 24rpx;
}

.calorie-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4CAF50;
}

.calorie-label {
  font-size: 24rpx;
  color: #777777;
  margin-top: 6rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 18rpx;
}

.candidate-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.candidate-item:last-child {
  border-bottom: none;
}

.candidate-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.candidate-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #888888;
}

.hint {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
  padding: 0 8rpx 24rpx;
}
