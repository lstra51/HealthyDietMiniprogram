.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 0;
  background-color: #f5f5f5;
  overflow: hidden;
}

.message-list {
  flex: 1;
  min-height: 0;
  padding: 20rpx 20rpx 20rpx 20rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
  gap: 20rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.message-item.user .avatar {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.message-content {
  max-width: calc(100% - 100rpx);
  padding: 24rpx 30rpx;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-all;
  background-color: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.message-item.user .message-content {
  background-color: #4CAF50;
  color: white;
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

.message-content.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: 0s;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.input-area {
  display: flex;
  flex-shrink: 0;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #e0e0e0;
  align-items: flex-end;
  gap: 20rpx;
}

.quick-actions {
  flex-shrink: 0;
  padding: 16rpx 20rpx 0;
  background-color: white;
  border-top: 1rpx solid #e0e0e0;
}

.quick-btn {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: #e8f5e9;
  color: #2e7d32;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.input-box {
  flex: 1;
  min-height: 80rpx;
  max-height: 200rpx;
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.send-btn:active {
  transform: scale(0.95);
}

.send-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}

.send-icon {
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}
