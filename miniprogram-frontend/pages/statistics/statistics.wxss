.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  background: white;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tabs {
  display: flex;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.tab.active {
  background: #4CAF50;
  color: white;
}

.avg-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 30rpx;
}

.avg-card {
  flex: 1;
  min-width: 150rpx;
  background: white;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.avg-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.avg-label {
  font-size: 22rpx;
  color: #999;
}

.chart-section {
  margin: 20rpx 30rpx;
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.trend-chart {
  width: 100%;
  height: 400rpx;
}

.pie-chart {
  width: 100%;
  height: 340rpx;
}

.pie-legend {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  min-width: 0;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.legend-text {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  flex: 1;
}

.legend-name {
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.legend-percent {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.empty-section {
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}
