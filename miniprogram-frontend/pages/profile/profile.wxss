.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.header-section {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 60rpx 20rpx 40rpx;
  text-align: center;
  color: #ffffff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 600;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
}

.health-card,
.no-health-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 28rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.edit-btn {
  font-size: 24rpx;
  color: #4CAF50;
}

.health-info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.info-item {
  text-align: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.info-value.goal {
  color: #4CAF50;
}

.bmi-section {
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.bmi-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.bmi-display {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.bmi-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #4CAF50;
}

.bmi-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.bmi-status.thin {
  background-color: #e3f2fd;
  color: #2196f3;
}

.bmi-status.normal {
  background-color: #e8f5e9;
  color: #4CAF50;
}

.bmi-status.overweight {
  background-color: #fff3e0;
  color: #ff9800;
}

.bmi-status.fat {
  background-color: #ffebee;
  color: #f44336;
}

.no-health-card {
  text-align: center;
}

.no-health-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.no-health-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.fill-health-btn {
  background-color: #4CAF50;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.menu-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.logout-section {
  padding: 0 20rpx;
}

.logout-btn {
  width: 100%;
  background-color: #ffffff;
  color: #f44336;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  border: none;
}
