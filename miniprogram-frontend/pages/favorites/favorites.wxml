<view class="page">
  <view class="header">
    <view class="title">我的收藏</view>
  </view>

  <view class="content">
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{favorites.length === 0}}" class="empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无收藏</text>
    </view>

    <view wx:else class="recipe-list">
      <view 
        wx:for="{{favorites}}" 
        wx:key="id" 
        class="recipe-card"
        bindtap="goToRecipeDetail"
        data-id="{{item.id}}"
      >
        <image class="recipe-image" src="{{item.image}}" mode="aspectFill" data-index="{{index}}" binderror="onImageError" />
        <view class="recipe-info">
          <view class="recipe-name">{{item.name}}</view>
          <view class="recipe-category">{{item.category}}</view>
          <view class="recipe-nutrition">
            <text class="nutrition-item">🔥 {{item.calories}}千卡</text>
            <text class="nutrition-item">🥩 {{item.protein}}g蛋白</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
