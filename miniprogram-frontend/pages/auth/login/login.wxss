.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  width: 80%;
  max-width: 360px;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background-color: #e0e0e0;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  border: 1rpx solid #dddddd;
  background-color: #fafafa;
  font-size: 28rpx;
  line-height: 88rpx;
}

.button-group {
  margin-top: 32rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 20rpx;
  font-size: 30rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background-color: #07c160;
  color: #ffffff;
}

.btn-plain {
  background-color: #ffffff;
  color: #333333;
  border: 1rpx solid #dddddd;
}

.btn-wechat {
  background-color: #07c160;
  color: #ffffff;
  margin-top: 0;
}

.btn-cancel {
  background-color: transparent;
  color: #999999;
  margin-top: 12rpx;
}

.wechat-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}
