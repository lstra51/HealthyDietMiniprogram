.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.welcome-section {
  padding: 20rpx 0 32rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.date {
  font-size: 26rpx;
  color: #999999;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.recommend-tag {
  font-size: 22rpx;
  color: #4CAF50;
  background-color: #e8f5e9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.recommend-content {
  display: flex;
  gap: 20rpx;
}

.recommend-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.dish-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.view-detail-btn {
  font-size: 24rpx;
  color: #4CAF50;
}

.action-card {
  text-align: center;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #ffffff;
}

.action-card .section-title {
  color: #ffffff;
  margin-bottom: 12rpx;
}

.action-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}

.action-btn {
  width: 100%;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}

.action-btn.primary {
  background-color: #ffffff;
  color: #4CAF50;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.entry-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.entry-label {
  font-size: 26rpx;
  color: #555555;
  text-align: center;
}

.login-tip-card {
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.login-tip-card .section-title {
  color: #ffffff;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}

.login-btn {
  width: 100%;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
  background-color: #ffffff;
  color: #667eea;
}
