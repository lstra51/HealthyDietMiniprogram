page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
}

button {
  border: none;
  outline: none;
  background: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

button::after {
  border: none;
}

input {
  outline: none;
}

view, text, image {
  box-sizing: border-box;
}

.scroll-view {
  box-sizing: border-box;
}
